# ─────────────────────────────────────────────
# Environment Variables — COPY TO .env AND FILL IN
# Never commit .env to version control!
# ─────────────────────────────────────────────

# NVD (National Vulnerability Database) API Key
# Get one free at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# Anthropic Claude API Key
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API Key (for Google ADK)
# Get one free at: https://aistudio.google.com/apikey → Create API key in new project
GOOGLE_API_KEY=your_google_api_key_here
